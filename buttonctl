#!/usr/bin/env python3
"""Button event helper for AIY Voice HAT v1."""

import argparse
import json
import math
import os
import shutil
import struct
import subprocess
import sys
import time


REPO_SPEC = "git+https://github.com/google/aiyprojects-raspbian.git@aiyprojects"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Read button press/release events from AIY Voice HAT v1."
    )
    parser.add_argument(
        "--edge",
        choices=["both", "press", "release"],
        default="both",
        help="Which edge(s) to emit (default: both).",
    )
    parser.add_argument(
        "--count",
        type=int,
        default=0,
        help="Stop after this many emitted events (0 = infinite).",
    )
    parser.add_argument(
        "--timeout",
        type=float,
        default=None,
        help="Stop after this many seconds.",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Emit JSON lines instead of plain text.",
    )
    parser.add_argument(
        "--mute",
        action="store_true",
        help="Disable quiet click tones on button events.",
    )
    return parser.parse_args()


def install_hint() -> str:
    if os.geteuid() == 0:
        return (
            "sudo python3 -m pip install --no-deps --break-system-packages "
            f"{REPO_SPEC}"
        )
    return (
        "python3 -m pip install --user --no-deps --break-system-packages "
        f"{REPO_SPEC}"
    )


def maybe_add_sudo_user_site() -> None:
    if os.geteuid() != 0:
        return
    sudo_user = os.environ.get("SUDO_USER")
    if not sudo_user:
        return
    pyver = f"{sys.version_info.major}.{sys.version_info.minor}"
    site = f"/home/{sudo_user}/.local/lib/python{pyver}/site-packages"
    if os.path.isdir(site) and site not in sys.path:
        sys.path.insert(0, site)


def import_board():
    maybe_add_sudo_user_site()
    try:
        from aiy.board import Board, Led
        return Board, Led
    except ImportError:
        print(
            "Missing dependency: aiy.board\n"
            "Install with:\n"
            f"  {install_hint()}",
            file=sys.stderr,
        )
        return None, None


def fmt_iso(ts: float) -> str:
    local = time.localtime(ts)
    millis = int((ts - int(ts)) * 1000)
    return time.strftime("%Y-%m-%dT%H:%M:%S", local) + f".{millis:03d}"


def emit(event: str, as_json: bool) -> None:
    ts = time.time()
    if as_json:
        print(
            json.dumps(
                {
                    "event": event,
                    "epoch": ts,
                    "time": fmt_iso(ts),
                },
                separators=(",", ":"),
            ),
            flush=True,
        )
    else:
        print(f"{fmt_iso(ts)} {event}", flush=True)


def remaining_time(start: float, timeout: float | None) -> float | None:
    if timeout is None:
        return None
    left = timeout - (time.monotonic() - start)
    if left <= 0:
        return 0.0
    return left


def permission_hint(err: Exception) -> bool:
    msg = str(err)
    if "No access to /dev/mem" not in msg:
        return False
    print(
        "GPIO permission denied.\n"
        "If you just added your user to the gpio group, start a new login session\n"
        "(or run: newgrp gpio).",
        file=sys.stderr,
    )
    return True


def tone_bytes(freq_hz: float, duration_s: float, volume: float, rate: int) -> bytes:
    total = max(1, int(duration_s * rate))
    amp = int(max(0.0, min(1.0, volume)) * 32767)
    out = bytearray(total * 2)
    for i in range(total):
        sample = int(amp * math.sin(2.0 * math.pi * freq_hz * i / rate))
        struct.pack_into("<h", out, i * 2, sample)
    return bytes(out)


class EventSound:
    def __init__(self, enabled: bool) -> None:
        self._rate = 16000
        self._enabled = enabled and shutil.which("aplay") is not None
        self._press = tone_bytes(freq_hz=1200, duration_s=0.025, volume=0.02, rate=self._rate)
        self._release = tone_bytes(freq_hz=900, duration_s=0.02, volume=0.015, rate=self._rate)

    def play(self, event: str) -> None:
        if not self._enabled:
            return
        data = self._press if event == "pressed" else self._release
        try:
            subprocess.run(
                [
                    "aplay",
                    "-q",
                    "-t",
                    "raw",
                    "-f",
                    "S16_LE",
                    "-r",
                    str(self._rate),
                    "-c",
                    "1",
                ],
                input=data,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=False,
                timeout=0.8,
            )
        except Exception:
            self._enabled = False


def main() -> int:
    args = parse_args()

    if args.count < 0:
        print("count must be >= 0", file=sys.stderr)
        return 2

    Board, Led = import_board()
    if Board is None:
        return 2

    emitted = 0
    start = time.monotonic()
    sound = EventSound(enabled=not args.mute)

    try:
        with Board() as board:
            try:
                board.led.state = Led.OFF

                while True:
                    if args.count and emitted >= args.count:
                        break

                    timeout = remaining_time(start, args.timeout)
                    if timeout is not None and timeout <= 0:
                        break

                    if not board.button.wait_for_press(timeout=timeout):
                        break
                    board.led.state = Led.ON
                    sound.play("pressed")

                    if args.edge in ("both", "press"):
                        emit("pressed", args.json)
                        emitted += 1
                        if args.count and emitted >= args.count:
                            break

                    timeout = remaining_time(start, args.timeout)
                    if timeout is not None and timeout <= 0:
                        break

                    if not board.button.wait_for_release(timeout=timeout):
                        break
                    board.led.state = Led.OFF
                    sound.play("released")

                    if args.edge in ("both", "release"):
                        emit("released", args.json)
                        emitted += 1
            finally:
                board.led.state = Led.OFF
                time.sleep(0.05)
    except RuntimeError as err:
        if permission_hint(err):
            return 3
        raise

    return 0


if __name__ == "__main__":
    raise SystemExit(main())

#!/usr/bin/env python3
"""Button event helper for AIY Voice HAT v1."""

import argparse
import json
import sys
import time


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Read button press/release events from AIY Voice HAT v1."
    )
    parser.add_argument(
        "--edge",
        choices=["both", "press", "release"],
        default="both",
        help="Which edge(s) to emit (default: both).",
    )
    parser.add_argument(
        "--count",
        type=int,
        default=0,
        help="Stop after this many emitted events (0 = infinite).",
    )
    parser.add_argument(
        "--timeout",
        type=float,
        default=None,
        help="Stop after this many seconds.",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Emit JSON lines instead of plain text.",
    )
    return parser.parse_args()


def fmt_iso(ts: float) -> str:
    local = time.localtime(ts)
    millis = int((ts - int(ts)) * 1000)
    return time.strftime("%Y-%m-%dT%H:%M:%S", local) + f".{millis:03d}"


def emit(event: str, as_json: bool) -> None:
    ts = time.time()
    if as_json:
        print(
            json.dumps(
                {
                    "event": event,
                    "epoch": ts,
                    "time": fmt_iso(ts),
                },
                separators=(",", ":"),
            ),
            flush=True,
        )
    else:
        print(f"{fmt_iso(ts)} {event}", flush=True)


def remaining_time(start: float, timeout: float | None) -> float | None:
    if timeout is None:
        return None
    left = timeout - (time.monotonic() - start)
    if left <= 0:
        return 0.0
    return left


def main() -> int:
    args = parse_args()

    if args.count < 0:
        print("count must be >= 0", file=sys.stderr)
        return 2

    try:
        from aiy.board import Board
    except ImportError:
        print(
            "Missing dependency: aiy.board\n"
            "Install with:\n"
            "  python3 -m pip install --user --no-deps --break-system-packages "
            "git+https://github.com/google/aiyprojects-raspbian.git@aiyprojects",
            file=sys.stderr,
        )
        return 2

    emitted = 0
    start = time.monotonic()

    with Board() as board:
        while True:
            if args.count and emitted >= args.count:
                break

            timeout = remaining_time(start, args.timeout)
            if timeout is not None and timeout <= 0:
                break

            if args.edge in ("both", "press"):
                if not board.button.wait_for_press(timeout=timeout):
                    break
                emit("pressed", args.json)
                emitted += 1
                if args.count and emitted >= args.count:
                    break
                timeout = remaining_time(start, args.timeout)
                if timeout is not None and timeout <= 0:
                    break

            if args.edge in ("both", "release"):
                if not board.button.wait_for_release(timeout=timeout):
                    break
                emit("released", args.json)
                emitted += 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
